generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String?  @unique
  isActive  Boolean  @default(true)
  timezone  String?  @default("America/Sao_Paulo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  contacts           Contact[]
  conversations      Conversation[]
  phoneNumbers       PhoneNumber[]
  campaigns          Campaign[]
  webhookEvents      WebhookEvent[]
  sessions           Session[]
  operationSettings  OperationSettings?
  aiConfig           OperationAiConfig?
  messageTemplates   MessageTemplate[]
  broadcasts         Broadcast[]
  whatsappConnections WhatsAppConnection[]
  aiAgents           AiAgent[]
}

model PhoneNumber {
  id                String                    @id @default(cuid())
  number            String                    @unique
  label             String?
  tenantId          String
  managerId         String?
  provider          MessageProvider           @default(WHATSAPP_CLOUD)
  providerAccountId String?
  externalId        String?
  whatsappConnectionId String?
  isActive          Boolean                   @default(true)
  isDefault         Boolean                   @default(false)
  profileName       String?
  profileAbout      String?
  profileImageUrl   String?
  connectionStatus  PhoneNumberConnectionStatus @default(DISCONNECTED)
  createdAt         DateTime                  @default(now())
  updatedAt         DateTime                  @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager        User?          @relation("PhoneNumberManager", fields: [managerId], references: [id], onDelete: SetNull)
  whatsappConnection WhatsAppConnection? @relation(fields: [whatsappConnectionId], references: [id], onDelete: SetNull)
  conversations  Conversation[]
  campaigns      Campaign[]
  webhookEvents  WebhookEvent[]

  @@index([tenantId, isActive])
  @@index([tenantId, managerId, isActive])
  @@index([externalId])
  @@index([whatsappConnectionId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  tenantId  String
  managerId String?
  role      UserRole @default(AGENT)
  isActive  Boolean  @default(true)
  presenceStatus PresenceStatus @default(AVAILABLE)

  // 🔐 AUTH
  passwordHash      String?
  lastLoginAt       DateTime?
  passwordUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager               User?          @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  teamMembers           User[]         @relation("UserManager")
  assignments           Assignment[]
  messages              Message[]
  assignedConversations Conversation[] @relation("ConversationAssignedUser")
  managedConversations  Conversation[] @relation("ConversationManager")
  managedCampaigns          Campaign[]                   @relation("CampaignManager")
  managedPhoneNumbers       PhoneNumber[]                @relation("PhoneNumberManager")
  managedDistributionRules  CampaignDistributionRule[]
  distributionMembers       CampaignDistributionMember[]
  assignedByEvents          Assignment[]                 @relation("AssignmentAssignedByUser")
  createdTemplates          MessageTemplate[]            @relation("MessageTemplateCreatedByUser")
  createdBroadcasts         Broadcast[]                  @relation("BroadcastCreatedByUser")

  // 🔐 SESSÕES
  sessions Session[]

  @@index([tenantId, role, isActive])
  @@index([tenantId, isActive])
  @@index([managerId])
}

model Session {
  id           String   @id @default(cuid())
  tokenHash    String   @unique
  userId       String
  tenantId     String
  expiresAt    DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  revokedAt    DateTime?

  ipAddress    String?
  userAgent    String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
}

model Contact {
  id            String   @id @default(cuid())
  name          String
  phone         String
  phoneRaw      String?
  email         String?
  tenantId      String
  externalId    String?
  flyImobLeadId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, phone])
  @@index([tenantId, name])
  @@index([externalId])
  @@index([flyImobLeadId])
}

model Campaign {
  id              String   @id @default(cuid())
  tenantId        String
  phoneNumberId   String
  managerId       String?
  name            String
  metaAdId        String?
  ref             String?
  fallbackText    String?
  initialPrompt   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber     PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  manager         User?       @relation("CampaignManager", fields: [managerId], references: [id], onDelete: SetNull)
  conversations     Conversation[]
  initialSteps      CampaignInitialStep[]
  followUpRules     CampaignFollowUpRule[]
  distributionRule  CampaignDistributionRule?
  aiConfig          CampaignAiConfig?

  @@index([tenantId, isActive])
  @@index([phoneNumberId, isActive])
  @@index([managerId, isActive])
  @@index([metaAdId])
  @@index([ref])
  @@index([tenantId, metaAdId])
}

model CampaignInitialStep {
  id           String                  @id @default(cuid())
  campaignId   String
  order        Int
  type         CampaignStepType
  content      String?
  mediaUrl     String?
  storageKey   String?
  mimeType     String?
  fileName     String?
  delaySeconds Int                     @default(0)
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  campaign     Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, order])
  @@index([campaignId, isActive, order])
}

model CampaignFollowUpRule {
  id              String                    @id @default(cuid())
  campaignId      String
  name            String
  triggerType     CampaignFollowUpTriggerType
  delaySeconds    Int
  type            CampaignStepType
  content         String
  isActive        Boolean                   @default(true)
  stopOnReply     Boolean                   @default(true)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  campaign        Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, isActive])
  @@index([campaignId, triggerType, isActive])
}

model CampaignDistributionRule {
  id                     String                   @id @default(cuid())
  campaignId             String                   @unique
  managerId              String
  mode                   CampaignDistributionMode @default(ROUND_ROBIN)
  isActive               Boolean                  @default(true)
  reassignOnTimeout      Boolean                  @default(false)
  responseTimeoutSeconds Int                      @default(300)
  viewTimeoutSeconds     Int?
  onlyBusinessHours      Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt

  campaign               Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  manager                User                      @relation(fields: [managerId], references: [id], onDelete: Cascade)
  members                CampaignDistributionMember[]

  @@index([managerId, isActive])
  @@index([mode, isActive])
}

model CampaignDistributionMember {
  id         String   @id @default(cuid())
  ruleId      String
  userId      String
  sortOrder   Int
  isActive    Boolean  @default(true)

  shiftStartHour   Int?   // 0-23
  shiftEndHour     Int?   // 0-23
  shiftDays        Int[]  // 0=domingo ... 6=sábado
  timezone         String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rule        CampaignDistributionRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  user        User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([ruleId, userId])
  @@unique([ruleId, sortOrder])
  @@index([userId, isActive])
}

model Conversation {
  id              String             @id @default(cuid())
  tenantId        String
  contactId       String
  phoneNumberId   String
  campaignId      String?
  managerId       String?
  assignedUserId  String?
  status          ConversationStatus @default(OPEN)
  channel         Channel            @default(WHATSAPP)
  mode            ConversationMode   @default(MANUAL)
  priority        ConversationPriority @default(NORMAL)
  subject         String?
  lastMessageAt   DateTime?
  lastSeenAt      DateTime?
  lastInboundAt   DateTime?
  lastOutboundAt  DateTime?
  waitingSince            DateTime?
  assignedAt              DateTime?
  firstResponseAt         DateTime?
  closedAt                DateTime?
  metaThreadId            String?

  queueCurrentUserId      String?
  queueStepStartedAt      DateTime?
  queueStepExpiresAt      DateTime?
  queueAttempt            Int      @default(0)

  automationKind           ConversationAutomationKind?
  automationStatus         ConversationAutomationStatus @default(IDLE)
  automationVersion        Int                          @default(1)
  currentAutomationStepOrder Int?
  automationStartedAt      DateTime?
  automationCompletedAt    DateTime?
  automationCancelledAt    DateTime?
  lastAutomationDispatchAt DateTime?
  nextAutomationAt         DateTime?

  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt
  aiState ConversationAiState?

  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneNumber  PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  campaign     Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  manager      User?       @relation("ConversationManager", fields: [managerId], references: [id], onDelete: SetNull)
  assignedUser User?       @relation("ConversationAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  messages    Message[]
  assignments Assignment[]

  @@index([tenantId, updatedAt])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, channel, status, updatedAt])
  @@index([tenantId, assignedUserId, updatedAt])
  @@index([tenantId, priority, updatedAt])
  @@index([tenantId, waitingSince])
  @@index([lastSeenAt])
  @@index([tenantId, assignedAt])
  @@index([phoneNumberId, updatedAt])
  @@index([contactId, updatedAt])
  @@index([tenantId, contactId, phoneNumberId, status])
  @@index([campaignId])
  @@index([managerId, updatedAt])
  @@index([tenantId, managerId, status, updatedAt])
  @@index([metaThreadId])
  @@index([queueCurrentUserId])
  @@index([queueStepExpiresAt])
  @@index([tenantId, queueStepExpiresAt])
  @@index([automationStatus, nextAutomationAt])
  @@index([tenantId, automationStatus, nextAutomationAt])
  @@index([tenantId, mode, automationStatus, nextAutomationAt])
  @@index([tenantId, campaignId, automationStatus])
}

model Message {
  id                  String              @id @default(cuid())
  conversationId      String
  senderUserId        String?
  senderType          MessageSenderType
  direction           MessageDirection
  type                MessageType
  status              MessageStatus       @default(QUEUED)
  provider            MessageProvider
  externalMessageId   String?
  externalStatus      String?
  externalMediaId     String?
  content             String?
  mediaUrl            String?
  storageKey          String?
  mimeType            String?
  fileName            String?
  durationSeconds     Int?
  latitude            Float?
  longitude           Float?
  locationName        String?
  locationAddress     String?
  transcription       String?
  transcriptionStatus TranscriptionStatus?
  failedReason        String?
  sentAt              DateTime?
  deliveredAt         DateTime?
  readAt              DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser   User?        @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([status, createdAt])
  @@index([direction, createdAt])
  @@index([externalMediaId])
  @@unique([provider, externalMessageId])
}

model Assignment {
  id               String   @id @default(cuid())
  conversationId   String
  userId           String
  assignedByUserId String?
  assignedAt       DateTime @default(now())
  unassignedAt     DateTime?
  reason           String?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedByUser User?        @relation("AssignmentAssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, assignedAt])
  @@index([conversationId, unassignedAt])
  @@index([userId, assignedAt])
}

model WebhookEvent {
  id              String             @id @default(cuid())
  tenantId        String
  phoneNumberId   String?
  provider        MessageProvider
  eventType       String?
  externalEventId String?
  eventHash       String
  payload         Json
  receivedAt      DateTime           @default(now())
  processedAt     DateTime?
  status          WebhookEventStatus @default(RECEIVED)
  errorMessage    String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)

  @@unique([provider, eventHash])
  @@index([tenantId, receivedAt])
  @@index([phoneNumberId, receivedAt])
  @@index([status, receivedAt])
  @@index([externalEventId])
}

model OperationSettings {
  id                          String   @id @default(cuid())
  tenantId                    String   @unique
  defaultSlaFirstResponseSec  Int      @default(300)
  allowManagerManualAssign    Boolean  @default(true)
  allowAgentSelfAssign        Boolean  @default(true)
  autoAssignEnabled           Boolean  @default(true)
  autoAssignOnlyAgents        Boolean  @default(true)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model OperationAiConfig {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  isEnabled        Boolean  @default(false)
  defaultMode      ConversationMode @default(AI)
  promptBase       String?
  handoffPrompt    String?
  fallbackBehavior String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model MessageTemplate {
  id               String                @id @default(cuid())
  tenantId         String
  createdByUserId  String?
  name             String
  category         TemplateCategory
  languageCode     String                @default("pt_BR")
  status           TemplateStatus        @default(DRAFT)
  providerTemplateId String?
  headerText       String?
  bodyText         String
  footerText       String?
  isActive         Boolean               @default(true)
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser  User?  @relation("MessageTemplateCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  broadcasts     Broadcast[]

  @@index([tenantId, category, isActive])
  @@index([tenantId, status, createdAt])
}

model Broadcast {
  id                String          @id @default(cuid())
  tenantId          String
  createdByUserId   String?
  templateId        String?
  name              String
  status            BroadcastStatus @default(DRAFT)
  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  audienceFilter    Json?
  messageBody       String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdByUser  User?           @relation("BroadcastCreatedByUser", fields: [createdByUserId], references: [id], onDelete: SetNull)
  template       MessageTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@index([tenantId, status, createdAt])
  @@index([tenantId, scheduledAt])
}

model WhatsAppConnection {
  id                 String                      @id @default(cuid())
  tenantId           String
  name               String
  provider           MessageProvider             @default(WHATSAPP_CLOUD)
  wabaId             String
  accessToken        String?
  tokenLastUpdatedAt DateTime?
  status             PhoneNumberConnectionStatus @default(CONNECTED)
  isDefault          Boolean                     @default(false)
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumbers PhoneNumber[]

  @@unique([tenantId, wabaId])
  @@index([tenantId, isDefault])
  @@index([wabaId])
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum ConversationMode {
  MANUAL
  AI
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBCHAT
}

enum UserRole {
  MASTER
  ADMIN
  MANAGER
  AGENT
}

enum PresenceStatus {
  AVAILABLE
  PAUSED
}

enum MessageSenderType {
  LEAD
  AGENT
  AI
  SYSTEM
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
  DOCUMENT
  VIDEO
  LOCATION
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageProvider {
  WHATSAPP_CLOUD
  INSTAGRAM
  FACEBOOK
  INTERNAL
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
enum CampaignStepType {
  TEXT
  AUDIO
  IMAGE
  DOCUMENT
  VIDEO
  LINK
}

enum CampaignFollowUpTriggerType {
  AFTER_LAST_INBOUND
  AFTER_LAST_INTERACTION
}

enum CampaignDistributionMode {
  ROUND_ROBIN
  ORDERED_QUEUE
  MANUAL_ONLY
  QUEUE_WITH_TIMEOUT
}

enum ConversationAutomationKind {
  INITIAL_SEQUENCE
  FOLLOW_UP
}

enum ConversationAutomationStatus {
  IDLE
  RUNNING
  COMPLETED
  CANCELLED
}

enum PhoneNumberConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  ERROR
}

enum TemplateCategory {
  UTILITY
  MARKETING
  AUTHENTICATION
}

enum TemplateStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ARCHIVED
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum AiResourceType {
  LINK
  AUDIO
  VIDEO
  IMAGE
  PDF
  DOCUMENT
  TEXT
}

enum AiKnowledgeTableType {
  SIMULATION
  DOCUMENTS
  PRICING
  FAQ
  CUSTOM
}

enum AiFollowupWindowType {
  SERVICE_24H
  ENTRY_POINT_72H
  TEMPLATE_AFTER_WINDOW
}

enum AiPromptVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model AiAgent {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  slug               String?
  description        String?
  isActive           Boolean  @default(true)

  model              String   @default("gpt-4o-mini")
  temperature        Float    @default(0.4)
  maxContextMessages Int      @default(12)

  objective          String?
  tone               String?
  basePrompt         String?
  safetyRules        String?
  handoffRules       String?
  businessRules      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  stages             AiStage[]
  objections         AiObjection[]
  resources          AiResource[]
  knowledgeTables    AiKnowledgeTable[]
  followupRules      AiFollowupRule[]
  successExamples    AiSuccessExample[]
  promptVersions     AiPromptVersion[]
  campaignConfigs    CampaignAiConfig[]
  conversationStates ConversationAiState[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
}

model AiStage {
  id        String   @id @default(cuid())
  agentId   String
  name      String
  order     Int
  objective String?
  instructions String?
  isActive  Boolean @default(true)

  agent     AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, order])
}

model AiObjection {
  id        String   @id @default(cuid())
  agentId   String
  stageId   String?
  title     String
  triggers  String?
  response  String?
  isActive  Boolean @default(true)

  agent     AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AiResource {
  id          String   @id @default(cuid())
  agentId     String
  type        AiResourceType
  title       String
  url         String?
  description String?
  isActive    Boolean @default(true)

  agent       AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AiKnowledgeTable {
  id          String   @id @default(cuid())
  agentId     String
  name        String
  type        AiKnowledgeTableType
  isActive    Boolean @default(true)

  agent       AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  rows        AiKnowledgeRow[]
}

model AiKnowledgeRow {
  id       String @id @default(cuid())
  tableId  String
  data     Json

  table    AiKnowledgeTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model AiFollowupRule {
  id          String   @id @default(cuid())
  agentId     String
  delayMinutes Int
  message     String
  windowType  AiFollowupWindowType
  isActive    Boolean @default(true)

  agent       AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AiSuccessExample {
  id          String   @id @default(cuid())
  agentId     String
  title       String
  transcript  String
  isActive    Boolean @default(true)

  agent       AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model AiPromptVersion {
  id        String   @id @default(cuid())
  agentId   String
  content   String
  status    AiPromptVersionStatus @default(DRAFT)

  agent     AiAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model CampaignAiConfig {
  id         String @id @default(cuid())
  campaignId String @unique
  agentId    String

  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  agent      AiAgent  @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model ConversationAiState {
  id             String   @id @default(cuid())
  conversationId String   @unique
  agentId        String
  currentStageId String?
  contextSummary String?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent          AiAgent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
}