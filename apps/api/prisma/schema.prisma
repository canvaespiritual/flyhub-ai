generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users         User[]
  contacts      Contact[]
  conversations Conversation[]
  phoneNumbers  PhoneNumber[]
  campaigns     Campaign[]
  webhookEvents WebhookEvent[]
  sessions Session[]
  
}

model PhoneNumber {
  id                String          @id @default(cuid())
  number            String          @unique
  label             String?
  tenantId          String
  provider          MessageProvider @default(WHATSAPP_CLOUD)
  providerAccountId String?
  externalId        String?
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  campaigns      Campaign[]
  webhookEvents  WebhookEvent[]

  @@index([tenantId, isActive])
  @@index([externalId])
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  tenantId  String
  managerId String?
  role      UserRole @default(AGENT)
  isActive  Boolean  @default(true)
  presenceStatus PresenceStatus @default(AVAILABLE)

  // 🔐 AUTH
  passwordHash      String?
  lastLoginAt       DateTime?
  passwordUpdatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant                Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  manager               User?          @relation("UserManager", fields: [managerId], references: [id], onDelete: SetNull)
  teamMembers           User[]         @relation("UserManager")
  assignments           Assignment[]
  messages              Message[]
  assignedConversations Conversation[] @relation("ConversationAssignedUser")
  managedConversations  Conversation[] @relation("ConversationManager")
  managedCampaigns      Campaign[]     @relation("CampaignManager")
  assignedByEvents      Assignment[]   @relation("AssignmentAssignedByUser")

  // 🔐 SESSÕES
  sessions Session[]

  @@index([tenantId, role, isActive])
  @@index([tenantId, isActive])
  @@index([managerId])
}

model Session {
  id           String   @id @default(cuid())
  tokenHash    String   @unique
  userId       String
  tenantId     String
  expiresAt    DateTime

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  revokedAt    DateTime?

  ipAddress    String?
  userAgent    String?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
}

model Contact {
  id            String   @id @default(cuid())
  name          String
  phone         String
  phoneRaw      String?
  email         String?
  tenantId      String
  externalId    String?
  flyImobLeadId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  conversations Conversation[]

  @@unique([tenantId, phone])
  @@index([tenantId, name])
  @@index([externalId])
  @@index([flyImobLeadId])
}

model Campaign {
  id              String   @id @default(cuid())
  tenantId        String
  phoneNumberId   String
  managerId       String?
  name            String
  metaAdId        String?
  ref             String?
  fallbackText    String?
  initialPrompt   String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber     PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  manager         User?       @relation("CampaignManager", fields: [managerId], references: [id], onDelete: SetNull)
  conversations   Conversation[]
  initialSteps    CampaignInitialStep[]
  followUpRules   CampaignFollowUpRule[]

  @@index([tenantId, isActive])
  @@index([phoneNumberId, isActive])
  @@index([managerId, isActive])
  @@index([metaAdId])
  @@index([ref])
  @@index([tenantId, metaAdId])
}

model CampaignInitialStep {
  id           String                  @id @default(cuid())
  campaignId   String
  order        Int
  type         CampaignStepType
  content      String
  delaySeconds Int                     @default(0)
  isActive     Boolean                 @default(true)
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt

  campaign     Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, order])
  @@index([campaignId, isActive, order])
}

model CampaignFollowUpRule {
  id              String                    @id @default(cuid())
  campaignId      String
  name            String
  triggerType     CampaignFollowUpTriggerType
  delaySeconds    Int
  type            CampaignStepType
  content         String
  isActive        Boolean                   @default(true)
  stopOnReply     Boolean                   @default(true)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt

  campaign        Campaign                  @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, isActive])
  @@index([campaignId, triggerType, isActive])
}

model Conversation {
  id              String             @id @default(cuid())
  tenantId        String
  contactId       String
  phoneNumberId   String
  campaignId      String?
  managerId       String?
  assignedUserId  String?
  status          ConversationStatus @default(OPEN)
  channel         Channel            @default(WHATSAPP)
  mode            ConversationMode   @default(MANUAL)
  priority        ConversationPriority @default(NORMAL)
  subject         String?
  lastMessageAt   DateTime?
  lastInboundAt   DateTime?
  lastOutboundAt  DateTime?
  waitingSince    DateTime?
  assignedAt      DateTime?
  firstResponseAt DateTime?
  closedAt        DateTime?
  metaThreadId             String?

  automationKind           ConversationAutomationKind?
  automationStatus         ConversationAutomationStatus @default(IDLE)
  automationVersion        Int                          @default(1)
  currentAutomationStepOrder Int?
  automationStartedAt      DateTime?
  automationCompletedAt    DateTime?
  automationCancelledAt    DateTime?
  lastAutomationDispatchAt DateTime?
  nextAutomationAt         DateTime?

  createdAt                DateTime                     @default(now())
  updatedAt                DateTime                     @updatedAt

   tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact      Contact     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneNumber  PhoneNumber @relation(fields: [phoneNumberId], references: [id], onDelete: Cascade)
  campaign     Campaign?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  manager      User?       @relation("ConversationManager", fields: [managerId], references: [id], onDelete: SetNull)
  assignedUser User?       @relation("ConversationAssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)

  messages    Message[]
  assignments Assignment[]

  @@index([tenantId, updatedAt])
  @@index([tenantId, status, updatedAt])
  @@index([tenantId, channel, status, updatedAt])
  @@index([tenantId, assignedUserId, updatedAt])
  @@index([tenantId, priority, updatedAt])
  @@index([tenantId, waitingSince])
  @@index([tenantId, assignedAt])
  @@index([phoneNumberId, updatedAt])
  @@index([contactId, updatedAt])
  @@index([tenantId, contactId, phoneNumberId, status])
  @@index([campaignId])
  @@index([managerId, updatedAt])
  @@index([tenantId, managerId, status, updatedAt])
  @@index([metaThreadId])
  @@index([automationStatus, nextAutomationAt])
  @@index([tenantId, automationStatus, nextAutomationAt])
  @@index([tenantId, mode, automationStatus, nextAutomationAt])
  @@index([tenantId, campaignId, automationStatus])
}

model Message {
  id                  String              @id @default(cuid())
  conversationId      String
  senderUserId        String?
  senderType          MessageSenderType
  direction           MessageDirection
  type                MessageType
  status              MessageStatus       @default(QUEUED)
  provider            MessageProvider
  externalMessageId   String?
  externalStatus      String?
  externalMediaId     String?
  content             String?
  mediaUrl            String?
  storageKey          String?
  mimeType            String?
  fileName            String?
  durationSeconds     Int?
  latitude            Float?
  longitude           Float?
  locationName        String?
  locationAddress     String?
  transcription       String?
  transcriptionStatus TranscriptionStatus?
  failedReason        String?
  sentAt              DateTime?
  deliveredAt         DateTime?
  readAt              DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderUser   User?        @relation(fields: [senderUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt])
  @@index([status, createdAt])
  @@index([direction, createdAt])
  @@index([externalMediaId])
  @@unique([provider, externalMessageId])
}

model Assignment {
  id               String   @id @default(cuid())
  conversationId   String
  userId           String
  assignedByUserId String?
  assignedAt       DateTime @default(now())
  unassignedAt     DateTime?
  reason           String?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedByUser User?        @relation("AssignmentAssignedByUser", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, assignedAt])
  @@index([conversationId, unassignedAt])
  @@index([userId, assignedAt])
}

model WebhookEvent {
  id              String             @id @default(cuid())
  tenantId        String
  phoneNumberId   String?
  provider        MessageProvider
  eventType       String?
  externalEventId String?
  eventHash       String
  payload         Json
  receivedAt      DateTime           @default(now())
  processedAt     DateTime?
  status          WebhookEventStatus @default(RECEIVED)
  errorMessage    String?

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  phoneNumber PhoneNumber? @relation(fields: [phoneNumberId], references: [id], onDelete: SetNull)

  @@unique([provider, eventHash])
  @@index([tenantId, receivedAt])
  @@index([phoneNumberId, receivedAt])
  @@index([status, receivedAt])
  @@index([externalEventId])
}

enum ConversationStatus {
  OPEN
  PENDING
  CLOSED
}

enum ConversationMode {
  MANUAL
  AI
}

enum ConversationPriority {
  LOW
  NORMAL
  HIGH
}

enum Channel {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  WEBCHAT
}

enum UserRole {
  MASTER
  ADMIN
  MANAGER
  AGENT
}

enum PresenceStatus {
  AVAILABLE
  PAUSED
}

enum MessageSenderType {
  LEAD
  AGENT
  AI
  SYSTEM
}

enum MessageType {
  TEXT
  AUDIO
  IMAGE
  DOCUMENT
  VIDEO
  LOCATION
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum MessageProvider {
  WHATSAPP_CLOUD
  INSTAGRAM
  FACEBOOK
  INTERNAL
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  IGNORED
  FAILED
}

enum TranscriptionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
enum CampaignStepType {
  TEXT
  AUDIO
  IMAGE
  LINK
}

enum CampaignFollowUpTriggerType {
  AFTER_LAST_INBOUND
  AFTER_LAST_INTERACTION
}

enum ConversationAutomationKind {
  INITIAL_SEQUENCE
  FOLLOW_UP
}

enum ConversationAutomationStatus {
  IDLE
  RUNNING
  COMPLETED
  CANCELLED
}